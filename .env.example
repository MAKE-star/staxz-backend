# ─── SERVER ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/staxz_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW=3600

# ─── TERMII (SMS/OTP) ─────────────────────────────────────────────────────────
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=Staxz
TERMII_BASE_URL=https://api.ng.termii.com

# ─── PAYSTACK ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
PLATFORM_FEE_PERCENT=15

# ─── CLOUDINARY ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── WHATSAPP (WATI) ──────────────────────────────────────────────────────────
WATI_API_URL=https://live-mt-server.wati.io/your_instance_id
WATI_ACCESS_TOKEN=your_wati_bearer_token
WATI_WEBHOOK_TOKEN=your_wati_webhook_verify_token

# ─── FIREBASE (FCM) ───────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# ─── CONTACT ENCRYPTION ───────────────────────────────────────────────────────
# 64-char hex string (32 bytes). Used to AES-256-GCM encrypt provider phone/address at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTACT_ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── GOOGLE MAPS ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── CAC VERIFICATION ─────────────────────────────────────────────────────────
CAC_VERIFY_API_URL=https://api.dojah.io
CAC_VERIFY_API_KEY=your_dojah_api_key
CAC_VERIFY_APP_ID=your_dojah_app_id

# ─── BOOKING TIMEOUTS ─────────────────────────────────────────────────────────
PROVIDER_RESPONSE_TIMEOUT_MINS=60
CLIENT_PAYMENT_TIMEOUT_MINS=30
AUTO_REFUND_AFTER_HOURS=48
LATE_CANCEL_WINDOW_MINS=120
LATE_CANCEL_FEE_PERCENT=20

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
